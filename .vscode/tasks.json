{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build UVL GLSP Server",
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "command": "mvn clean verify",
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "problemMatcher": []
    },
    {
      "label": "Start UVL Server",
      "type": "shell",
      "group": "test",
      "command": "java -jar target/uvl.glsp-0.5.1-glsp.jar",
      "options": {
        "cwd": "${workspaceFolder}/server/uvl.glsp"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Start UVL BP Server",
      "type": "shell",
      "group": "test",
      "command": "java -jar target/uvl.bp.glsp-0.5.1-glsp.jar",
      "options": {
        "cwd": "${workspaceFolder}/server/uvl.bp.glsp"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Install UVL VS Code Extension",
      "type": "shell",
      "group": "test",
      "command": "code --install-extension uvl-vscode.vsix",
      "options": {
        "cwd": "${workspaceFolder}/client/vscode/extension"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}