{
  "name": "uvl-client",
  "version": "0.3.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://git-st.inf.tu-dresden.de/stgroup/student-projects/2026/ma-nick-ruider.git"
  },
  "license": "MIT",
  "author": {
    "name": "Nick Ruider"
  },
  "contributors": [
    {
      "name": "Nick Ruider",
      "email": "nick.ruider@mailbox.tu-dresden.de",
      "url": "https://github.com/xXNicksdaXx"
    }
  ],
  "workspaces": [
    "extensions/*",
    "packages/*",
    "vscode/*"
  ],
  "scripts": {
    "all": "yarn clean && yarn install --ignore-scripts && yarn lint && yarn build",
    "build": "lerna run build",
    "build:uvl": "yarn uvl-sprotty build && yarn vs-code-webview bundle:prod:uvl && yarn vs-code-extension bundle:prod:uvl",
    "build:uvl-bp": "yarn uvl-sprotty build && yarn uvl-bp-sprotty build && yarn vs-code-webview bundle:prod:uvl-bp && yarn vs-code-extension bundle:prod:uvl-bp",
    "clean": "lerna run clean",
    "lint": "lerna run lint",
    "lint:fix": "lerna run lint:fix",
    "lint:ci": "lerna run lint:ci",
    "package": "yarn package:uvl",
    "package:uvl": "yarn build:uvl && yarn vs-code-extension package --env profile=uvl",
    "package:uvl-bp": "yarn build:uvl-bp && yarn vs-code-extension package --env profile=uvl-bp",
    "prepare": "yarn build",
    "uvl-bp-sprotty": "yarn --cwd extensions/bp-sprotty",
    "uvl-command-contribution": "yarn --cwd packages/uvl-command-contribution",
    "uvl-common": "yarn --cwd packages/common",
    "uvl-sprotty": "yarn --cwd packages/uvl-sprotty",
    "vs-code-extension": "yarn --cwd vscode/extension",
    "vs-code-webview": "yarn --cwd vscode/webview",
    "watch:vs-code": "concurrently \"yarn vs-code-webview watch\" \"yarn vs-code-extension watch\""
  },
  "devDependencies": {
    "@eclipse-glsp/config": "2.6.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "lerna": "^9.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=20 <25",
    "yarn": ">=1.7.0 <2"
  }
}
