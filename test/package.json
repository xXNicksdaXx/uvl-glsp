{
  "name": "uvl-playwright-test",
  "version": "0.2.0",
  "private": true,
  "description": "Playwright tests for UVL GLSP",
  "repository": {
    "type": "git",
    "url": "https://git-st.inf.tu-dresden.de/stgroup/student-projects/2026/ma-nick-ruider.git"
  },
  "license": "MIT",
  "author": {
    "name": "Nick Ruider"
  },
  "contributors": [
    {
      "name": "Nick Ruider",
      "email": "nick.ruider@mailbox.tu-dresden.de",
      "url": "https://github.com/xXNicksdaXx"
    }
  ],
  "main": "index",
  "types": "index",
  "files": [
    "src",
    "tests"
  ],
  "scripts": {
    "clean": "rimraf lib tsconfig.tsbuildinfo .vscode-test playwright-report test-results",
    "lint": "eslint --ext .ts ./src ./tests",
    "lint:fix": "eslint --ext .ts ./src ./tests --fix",
    "lint:ci": "yarn lint --output-file eslint_report.json --format json",
    "prepare": "playwright install",
    "test": "playwright test",
    "test:vscode": "yarn test --project=vscode",
    "test:vscode-setup": "yarn test --project=vscode-setup"
  },
  "dependencies": {
    "@eclipse-glsp/client": "2.5.0",
    "balloon-css": "^1.2.0",
    "inversify": "^6.1.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eclipse-glsp/glsp-playwright": "2.5.0",
    "@playwright/test": "^1.58.2",
    "@theia/playwright": "~1.64.0",
    "@types/node": "20.x",
    "eslint": "^9.37.0",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-null": "^1.0.2",
    "reflect-metadata": "~0.2.2",
    "rimraf": "5.0.10",
    "typescript": "^5.9.3",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=20 <21",
    "yarn": ">=1.7.0 <2"
  }
}
